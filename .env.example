# ---------------------------------------------------
# Minecraft Bot Configuration
#
# Make a copy of this file and name it .env
# Then, fill in the values below.
# ---------------------------------------------------

# -- Server Connection --
# The IP address or hostname of the Minecraft server.
# For a server on your own computer, this is usually 'localhost'.
MINECRAFT_HOST=localhost

# The port of the Minecraft server.
# The default for Java Edition is 25565.
MINECRAFT_PORT=25565

# The Minecraft version of the server.
# It's important this matches the server's version.
MINECRAFT_VERSION=1.20.1


# -- Bot Account --
# The username for the bot.
# For online-mode servers, this must be a valid Minecraft account.
# For offline-mode servers, this can be any name.
MINECRAFT_USERNAME=GeminiBot

# The authentication method.
# Use 'microsoft' for servers in online mode (requires a paid Minecraft account).
# Use 'offline' for servers in offline mode.
# If you use 'microsoft', you may need to follow additional steps in your terminal on first login.
# MINECRAFT_AUTH=microsoft


# -- AI and Control --
# Your API key from Google AI Studio for the Gemini model.
# This is required for the bot's AI to function.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# The Minecraft username of the player who will control the bot.
# The bot will only listen to commands from this player.
MASTER_PLAYER_NAME=YourMinecraftUsernameHere
